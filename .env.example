# Copy to .env (which is gitignored) and fill in your values.
# Start the daemon with:  npm start
# Node reads this file natively via --env-file; no secrets ever get typed
# into a terminal you might be screen-recording.

# Pin the API token so restarting the daemon doesn't strand a running agent
# plugin on a stale token. Any long random string.
CLAWGUARD_TOKEN=change-me-to-a-long-random-string

# --- Telegram approvals (recommended; ~3 min setup) ---
# Bot token from @BotFather. Treat as a password.
TG_BOT_TOKEN=
# Your numeric Telegram user id from @userinfobot. Digits only, comma-separated for several.
TG_APPROVERS=

# --- WhatsApp approvals (optional; see relay/README.md) ---
# WA_ACCESS_TOKEN=
# WA_PHONE_NUMBER_ID=
# WA_APPROVERS=
# WA_RELAY_URL=
# WA_RELAY_TOKEN=
# Per-approver pairing PINs ("<number>:<pin>", comma-separated). With a PIN
# set, that approver must quote it in every reply (YES ABC123 4832) — a
# spoofed or hijacked WhatsApp sender number alone can no longer approve.
# WA_APPROVER_PINS=+919876543210:4832
